// Firestore Security Rules
// Firebase Console > Firestore > Rules me ye paste karo
// Ye rules ensure karte hain ki har user sirf apna data read/write kar sake

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User ka expenses collection - sirf wahi user access kar sake
    match /users/{userId}/expenses/{expenseId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User ka incomes collection - sirf wahi user access kar sake
    match /users/{userId}/incomes/{incomeId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Baaki sab block - koi aur collection access nahi kar sakta
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
