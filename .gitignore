# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============================================================================
# DEPENDENCIES & PACKAGE MANAGERS
# ============================================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================================================================
# TESTING
# ============================================================================
/coverage

# ============================================================================
# NEXT.JS BUILD OUTPUT
# ============================================================================
# Next.js build directory and out directory
/.next/
/out/

# ============================================================================
# PRODUCTION & BUILD
# ============================================================================
/build
dist/

# ============================================================================
# ENVIRONMENT VARIABLES
# ============================================================================
# Local environment files (never commit sensitive data)
.env*
!.env.example

# ============================================================================
# OPERATING SYSTEM FILES
# ============================================================================
# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Windows
ehthumbs.db
Thumbs.db

# Linux
.directory

# ============================================================================
# IDE & EDITOR CONFIGS
# ============================================================================
# VS Code
.vscode/
*.code-workspace

# IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim
*.swp
*.swo
*~

# Emacs
*~
.\#*

# ============================================================================
# DEBUGGING & LOGS
# ============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
lerna-debug.log*

# ============================================================================
# VERCEL DEPLOYMENT
# ============================================================================
.vercel

# ============================================================================
# TYPESCRIPT
# ============================================================================
*.tsbuildinfo
next-env.d.ts

# ============================================================================
# TEMPORARY FILES
# ============================================================================
*.tmp
*.temp
.cache/

# ============================================================================
# GIT MERGE FILES
# ============================================================================
*.orig
*.rej
